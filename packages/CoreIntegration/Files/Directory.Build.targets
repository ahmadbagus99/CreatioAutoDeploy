<Project>
	<ItemGroup Condition="'$(PkgPath)' != ''">
		<Compile Remove="$(PkgPath)/CoreIntegration/Assemblies/**" />
		<Compile Remove="$(PkgPath)/CoreIntegration/Data/**" />
		<Compile Remove="$(PkgPath)/CoreIntegration/SqlScripts/**" />
		<Compile Remove="$(PkgPath)/CoreIntegration/Schemas\**" />
		<Compile Remove="$(PkgPath)/CoreIntegration/Resources/**" />
		<EmbeddedResource Remove="$(PkgPath)/CoreIntegration/Assemblies/**" />
		<EmbeddedResource Remove="$(PkgPath)/CoreIntegration/Data/**" />
		<EmbeddedResource Remove="$(PkgPath)/CoreIntegration/SqlScripts/**" />
		<EmbeddedResource Remove="$(PkgPath)/CoreIntegration/Schemas/**" />
		<EmbeddedResource Remove="$(PkgPath)/CoreIntegration/Resources/**" />
		<None Remove="$(PkgPath)/CoreIntegration/Assemblies/**" />
		<None Remove="$(PkgPath)/CoreIntegration/Data/**" />
		<None Remove="$(PkgPath)/CoreIntegration/SqlScripts/**" />
		<None Remove="$(PkgPath)/CoreIntegration/Schemas/**" />
		<None Remove="$(PkgPath)/CoreIntegration/Resources/**" />
  </ItemGroup>
</Project>