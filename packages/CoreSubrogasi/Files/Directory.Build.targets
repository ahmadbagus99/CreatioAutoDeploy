<Project>
	<ItemGroup Condition="'$(PkgPath)' != ''">
		<Compile Remove="$(PkgPath)/CoreSubrogasi/Assemblies/**" />
		<Compile Remove="$(PkgPath)/CoreSubrogasi/Data/**" />
		<Compile Remove="$(PkgPath)/CoreSubrogasi/SqlScripts/**" />
		<Compile Remove="$(PkgPath)/CoreSubrogasi/Schemas\**" />
		<Compile Remove="$(PkgPath)/CoreSubrogasi/Resources/**" />
		<EmbeddedResource Remove="$(PkgPath)/CoreSubrogasi/Assemblies/**" />
		<EmbeddedResource Remove="$(PkgPath)/CoreSubrogasi/Data/**" />
		<EmbeddedResource Remove="$(PkgPath)/CoreSubrogasi/SqlScripts/**" />
		<EmbeddedResource Remove="$(PkgPath)/CoreSubrogasi/Schemas/**" />
		<EmbeddedResource Remove="$(PkgPath)/CoreSubrogasi/Resources/**" />
		<None Remove="$(PkgPath)/CoreSubrogasi/Assemblies/**" />
		<None Remove="$(PkgPath)/CoreSubrogasi/Data/**" />
		<None Remove="$(PkgPath)/CoreSubrogasi/SqlScripts/**" />
		<None Remove="$(PkgPath)/CoreSubrogasi/Schemas/**" />
		<None Remove="$(PkgPath)/CoreSubrogasi/Resources/**" />
  </ItemGroup>
</Project>